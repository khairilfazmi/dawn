{% comment %}
=============================================================
  RidePaw Pet Adventure Bike Basket — Landing Page Section
  File: sections/pet-bike-basket.liquid

  Sections:
    §1  Hero
    §2  Trust Bar
    §3  Features Grid ("Why Riders Love It")
    §4  How It Works
    §5  Compatibility Callout
    §6  Lifestyle / Emotional
    §7  What's In The Box
    §8  FAQ Accordion
    §9  Final CTA

  CSS: scoped with .rpb-* prefix, vars at .rpb-root
  JS:  FAQ accordion + IntersectionObserver scroll-in

  Setup:
    1. In Theme Customizer → Pages → [your page] → Section settings
    2. Enter the product handle for your basket product
    3. Replace [HERO IMAGE] and [LIFESTYLE IMAGE] placeholders with
       real Shopify hosted image URLs
=============================================================
{% endcomment %}

{%- assign lp = all_products[section.settings.product_handle] -%}

{%- style -%}
/* ============================================================
   RidePaw Landing Page — Scoped Styles
   All classes prefixed .rpb- to avoid Dawn theme collisions
   ============================================================ */

.rpb-root {
  --rpb-green:      #2D5A27;
  --rpb-green-dark: #1e3f1b;
  --rpb-green-light:#eef3ed;
  --rpb-beige:      #F5ECD7;
  --rpb-white:      #FAFAF7;
  --rpb-charcoal:   #2C2C2C;
  --rpb-gray:       #9a9a9a;
  --rpb-radius:     10px;
  --rpb-radius-lg:  16px;
  --rpb-font:       -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --rpb-shadow:     0 2px 16px rgba(0,0,0,0.08);
  --rpb-shadow-lg:  0 8px 32px rgba(0,0,0,0.12);
  --rpb-max-width:  1200px;
  --rpb-transition: 0.25s ease;

  font-family: var(--rpb-font);
  color: var(--rpb-charcoal);
  -webkit-font-smoothing: antialiased;
}

/* ---- Utilities ---- */
.rpb-container {
  max-width: var(--rpb-max-width);
  margin: 0 auto;
  padding: 0 24px;
}

/* ---- Buttons ---- */
.rpb-btn {
  display: inline-block;
  padding: 14px 32px;
  border-radius: var(--rpb-radius);
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: background var(--rpb-transition), transform var(--rpb-transition), box-shadow var(--rpb-transition);
  border: 2px solid transparent;
  text-decoration: none;
  text-align: center;
  line-height: 1.2;
  font-family: var(--rpb-font);
}

.rpb-btn--primary {
  background: var(--rpb-green);
  color: #fff;
  border-color: var(--rpb-green);
}

.rpb-btn--primary:hover,
.rpb-btn--primary:focus {
  background: var(--rpb-green-dark);
  border-color: var(--rpb-green-dark);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(45,90,39,0.3);
  color: #fff;
  text-decoration: none;
}

.rpb-btn--lg {
  padding: 18px 48px;
  font-size: 18px;
  border-radius: 12px;
}

/* ---- Scroll-in animation ---- */
.rpb-animate {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}

.rpb-animate.rpb-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================================
   §1 HERO
   ============================================================ */
.rpb-hero {
  background: var(--rpb-white);
  min-height: 90vh;
  display: flex;
  align-items: center;
  padding: 80px 0;
  overflow: hidden;
}

.rpb-hero__inner {
  display: flex;
  flex-direction: column;
  gap: 48px;
  align-items: center;
}

.rpb-hero__copy {
  flex: 1;
  max-width: 600px;
}

.rpb-hero__eyebrow {
  display: inline-block;
  background: var(--rpb-green-light);
  color: var(--rpb-green);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 20px;
  margin-bottom: 20px;
}

.rpb-hero__headline {
  font-size: clamp(36px, 5.5vw, 62px);
  font-weight: 800;
  line-height: 1.1;
  color: var(--rpb-charcoal);
  margin: 0 0 20px;
}

.rpb-hero__headline em {
  font-style: normal;
  color: var(--rpb-green);
}

.rpb-hero__subheadline {
  font-size: 18px;
  line-height: 1.65;
  color: #555;
  margin: 0 0 32px;
  max-width: 520px;
}

.rpb-hero__meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}

.rpb-hero__price {
  font-size: 28px;
  font-weight: 700;
  color: var(--rpb-charcoal);
}

.rpb-hero__badge {
  font-size: 13px;
  color: #666;
  background: var(--rpb-beige);
  padding: 4px 12px;
  border-radius: 20px;
}

.rpb-hero__actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: 20px;
}

.rpb-hero__trust-note {
  font-size: 13px;
  color: var(--rpb-gray);
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin: 0;
}

.rpb-hero__image-wrap {
  flex: 1;
  width: 100%;
  max-width: 560px;
  position: relative;
}

.rpb-hero__image-wrap::before {
  content: '';
  position: absolute;
  width: 280px;
  height: 280px;
  background: var(--rpb-beige);
  border-radius: 50%;
  top: -32px;
  right: -40px;
  z-index: 0;
}

.rpb-img-placeholder {
  background: #e8e4de;
  border-radius: var(--rpb-radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-align: center;
  padding: 24px;
  gap: 8px;
  position: relative;
  z-index: 1;
}

.rpb-img-placeholder small {
  font-size: 12px;
  opacity: 0.7;
  font-weight: 400;
}

.rpb-hero__image-wrap .rpb-img-placeholder {
  height: 500px;
}

/* ============================================================
   §2 TRUST BAR
   ============================================================ */
.rpb-trust {
  background: var(--rpb-green);
  padding: 0;
}

.rpb-trust__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

.rpb-trust__item {
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 16px 28px;
  position: relative;
  white-space: nowrap;
}

.rpb-trust__item + .rpb-trust__item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 20px;
  width: 1px;
  background: rgba(255,255,255,0.3);
}

.rpb-trust__icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

/* ============================================================
   §3 FEATURES GRID
   ============================================================ */
.rpb-features {
  background: var(--rpb-beige);
  padding: 80px 0;
}

.rpb-section-header {
  text-align: center;
  margin-bottom: 52px;
}

.rpb-section-label {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--rpb-green);
  margin-bottom: 12px;
}

.rpb-section-title {
  font-size: clamp(26px, 3.5vw, 40px);
  font-weight: 800;
  color: var(--rpb-charcoal);
  margin: 0 0 12px;
  line-height: 1.2;
}

.rpb-section-subtitle {
  font-size: 17px;
  color: #666;
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.6;
}

.rpb-features__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

.rpb-feature-card {
  background: var(--rpb-white);
  border-radius: var(--rpb-radius);
  padding: 32px 28px;
  box-shadow: var(--rpb-shadow);
  border-top: 4px solid var(--rpb-green);
  transition: transform var(--rpb-transition), box-shadow var(--rpb-transition);
}

.rpb-feature-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--rpb-shadow-lg);
}

.rpb-feature-card__icon {
  width: 44px;
  height: 44px;
  margin-bottom: 18px;
  color: var(--rpb-green);
}

.rpb-feature-card__title {
  font-size: 17px;
  font-weight: 700;
  color: var(--rpb-charcoal);
  margin: 0 0 10px;
}

.rpb-feature-card__desc {
  font-size: 15px;
  line-height: 1.65;
  color: #666;
  margin: 0;
}

/* ============================================================
   §4 HOW IT WORKS
   ============================================================ */
.rpb-how {
  background: var(--rpb-white);
  padding: 80px 0;
}

.rpb-how__steps {
  display: flex;
  flex-direction: column;
  gap: 32px;
  margin-top: 52px;
}

.rpb-how__step {
  display: flex;
  gap: 24px;
  align-items: flex-start;
}

.rpb-how__num {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  background: var(--rpb-green);
  color: #fff;
  font-size: 22px;
  font-weight: 800;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(45,90,39,0.25);
}

.rpb-how__step-title {
  font-size: 19px;
  font-weight: 700;
  margin: 0 0 8px;
  color: var(--rpb-charcoal);
  padding-top: 8px;
}

.rpb-how__step-desc {
  font-size: 15px;
  color: #666;
  line-height: 1.65;
  margin: 0;
}

/* ============================================================
   §5 COMPATIBILITY CALLOUT
   ============================================================ */
.rpb-compat {
  background: var(--rpb-beige);
  padding: 80px 0;
}

.rpb-compat__box {
  max-width: 860px;
  margin: 0 auto;
  background: var(--rpb-white);
  border: 2px solid var(--rpb-green);
  border-radius: var(--rpb-radius-lg);
  padding: 48px;
}

.rpb-compat__header {
  text-align: center;
  margin-bottom: 36px;
}

.rpb-compat__emoji {
  font-size: 40px;
  margin-bottom: 12px;
  line-height: 1;
}

.rpb-compat__title {
  font-size: 26px;
  font-weight: 800;
  color: var(--rpb-charcoal);
  margin: 0 0 8px;
}

.rpb-compat__sub {
  font-size: 15px;
  color: #777;
  margin: 0;
}

.rpb-compat__cols {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
}

.rpb-compat__col-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin: 0 0 14px;
}

.rpb-compat__col--yes .rpb-compat__col-title { color: var(--rpb-green); }
.rpb-compat__col--no  .rpb-compat__col-title { color: #c0392b; }

.rpb-compat__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.rpb-compat__list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 15px;
  color: var(--rpb-charcoal);
  line-height: 1.5;
}

.rpb-compat__check { color: var(--rpb-green); font-weight: 700; flex-shrink: 0; }
.rpb-compat__x     { color: #c0392b;          font-weight: 700; flex-shrink: 0; }

.rpb-compat__note {
  margin-top: 28px;
  padding: 16px 20px;
  background: var(--rpb-green-light);
  border-radius: var(--rpb-radius);
  font-size: 14px;
  color: #444;
  line-height: 1.65;
  font-style: italic;
  border-left: 3px solid var(--rpb-green);
}

/* ============================================================
   §6 LIFESTYLE / EMOTIONAL
   ============================================================ */
.rpb-lifestyle {
  background: var(--rpb-beige);
  padding: 80px 0;
}

.rpb-lifestyle__inner {
  display: flex;
  flex-direction: column;
  gap: 40px;
  align-items: center;
}

.rpb-lifestyle__image {
  width: 100%;
}

.rpb-lifestyle__image .rpb-img-placeholder {
  height: 380px;
}

.rpb-lifestyle__copy {
  max-width: 520px;
}

.rpb-lifestyle__quote {
  font-size: clamp(22px, 2.8vw, 30px);
  font-weight: 700;
  line-height: 1.4;
  color: var(--rpb-charcoal);
  margin: 12px 0 20px;
  font-style: italic;
}

.rpb-lifestyle__body {
  font-size: 17px;
  line-height: 1.7;
  color: #555;
  margin: 0 0 32px;
}

/* ============================================================
   §7 WHAT'S IN THE BOX
   ============================================================ */
.rpb-inbox {
  background: var(--rpb-white);
  padding: 80px 0;
  text-align: center;
}

.rpb-inbox__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  margin: 40px auto 28px;
  max-width: 720px;
  text-align: left;
}

.rpb-inbox__item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 20px;
  background: var(--rpb-beige);
  border-radius: var(--rpb-radius);
}

.rpb-inbox__icon {
  font-size: 26px;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 2px;
}

.rpb-inbox__name {
  font-size: 15px;
  font-weight: 600;
  color: var(--rpb-charcoal);
  margin: 0 0 3px;
}

.rpb-inbox__qty {
  font-size: 13px;
  color: #888;
  margin: 0;
}

.rpb-inbox__note {
  font-size: 14px;
  color: #777;
  font-style: italic;
  max-width: 500px;
  margin: 0 auto;
  line-height: 1.6;
}

/* ============================================================
   §8 FAQ ACCORDION
   ============================================================ */
.rpb-faq {
  background: var(--rpb-beige);
  padding: 80px 0;
}

.rpb-faq__list {
  max-width: 760px;
  margin: 48px auto 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.rpb-faq-item {
  background: var(--rpb-white);
  border-radius: var(--rpb-radius);
  box-shadow: var(--rpb-shadow);
  overflow: hidden;
}

.rpb-faq-trigger {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22px 24px;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  gap: 16px;
  font-family: var(--rpb-font);
  color: var(--rpb-charcoal);
}

.rpb-faq-trigger:hover {
  background: rgba(45,90,39,0.04);
}

.rpb-faq-question {
  font-size: 16px;
  font-weight: 600;
  color: var(--rpb-charcoal);
  line-height: 1.4;
}

.rpb-faq-chevron {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  color: var(--rpb-green);
  transition: transform 0.3s ease;
}

.rpb-faq-item--open .rpb-faq-chevron {
  transform: rotate(180deg);
}

.rpb-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
}

.rpb-faq-answer-inner {
  padding: 16px 24px 22px;
  font-size: 15px;
  line-height: 1.7;
  color: #555;
  border-top: 1px solid rgba(0,0,0,0.06);
}

/* ============================================================
   §9 FINAL CTA
   ============================================================ */
.rpb-cta {
  background: var(--rpb-green);
  padding: 100px 0;
  text-align: center;
}

.rpb-cta__eyebrow {
  color: rgba(255,255,255,0.65);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin: 0 0 16px;
}

.rpb-cta__headline {
  font-size: clamp(32px, 4.5vw, 56px);
  font-weight: 800;
  color: #fff;
  margin: 0 0 16px;
  line-height: 1.15;
}

.rpb-cta__sub {
  font-size: 18px;
  color: rgba(255,255,255,0.75);
  margin: 0 0 40px;
  line-height: 1.6;
}

.rpb-cta__form {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.rpb-cta__btn {
  background: var(--rpb-beige);
  color: var(--rpb-green);
  border: 2px solid var(--rpb-beige);
  font-size: 18px;
  font-weight: 800;
  padding: 18px 56px;
  border-radius: 12px;
  cursor: pointer;
  font-family: var(--rpb-font);
  transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  text-decoration: none;
  display: inline-block;
}

.rpb-cta__btn:hover,
.rpb-cta__btn:focus {
  background: #fff;
  border-color: #fff;
  color: var(--rpb-green-dark);
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(0,0,0,0.2);
}

.rpb-cta__secure {
  color: rgba(255,255,255,0.5);
  font-size: 13px;
  margin: 0;
}

/* ============================================================
   RESPONSIVE — 768px+
   ============================================================ */
@media (min-width: 768px) {
  .rpb-features__grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .rpb-how__steps {
    flex-direction: row;
    gap: 0;
    align-items: flex-start;
    position: relative;
  }

  .rpb-how__step {
    flex: 1;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px;
    position: relative;
  }

  .rpb-how__step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 27px;
    left: calc(50% + 40px);
    right: calc(-50% + 40px);
    height: 2px;
    border-top: 2px dashed rgba(45,90,39,0.3);
  }

  .rpb-how__step-title {
    padding-top: 20px;
  }

  .rpb-compat__cols {
    grid-template-columns: 1fr 1fr;
  }

  .rpb-lifestyle__inner {
    flex-direction: row;
    gap: 60px;
    align-items: center;
  }

  .rpb-lifestyle__image {
    flex: 1;
  }

  .rpb-lifestyle__copy {
    flex: 1;
  }
}

/* ============================================================
   RESPONSIVE — 1024px+
   ============================================================ */
@media (min-width: 1024px) {
  .rpb-hero__inner {
    flex-direction: row;
    align-items: center;
  }

  .rpb-hero__copy {
    max-width: 540px;
  }

  .rpb-features__grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .rpb-inbox__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* ============================================================
   RESPONSIVE — mobile overrides
   ============================================================ */
@media (max-width: 767px) {
  .rpb-hero {
    min-height: auto;
    padding: 56px 0 40px;
  }

  .rpb-hero__image-wrap::before {
    display: none;
  }

  .rpb-hero__image-wrap .rpb-img-placeholder {
    height: 260px;
  }

  .rpb-trust__item {
    padding: 10px 16px;
    font-size: 13px;
  }

  .rpb-trust__item + .rpb-trust__item::before {
    display: none;
  }

  .rpb-compat__box {
    padding: 28px 20px;
  }

  .rpb-inbox__grid {
    grid-template-columns: 1fr;
    max-width: 380px;
  }

  .rpb-features,
  .rpb-how,
  .rpb-compat,
  .rpb-lifestyle,
  .rpb-inbox,
  .rpb-faq,
  .rpb-cta {
    padding: 56px 0;
  }
}
{%- endstyle -%}

<div class="rpb-root">

  {% comment %} ===== §1 HERO ===== {% endcomment %}
  <section class="rpb-hero" aria-label="Hero">
    <div class="rpb-container">
      <div class="rpb-hero__inner">

        <div class="rpb-hero__copy rpb-animate">
          <span class="rpb-hero__eyebrow">RidePaw &mdash; Pet Adventure Basket</span>
          <h1 class="rpb-hero__headline">
            Every Ride Is<br><em>Better With Them.</em>
          </h1>
          <p class="rpb-hero__subheadline">
            The 3-in-1 basket that clips to your handlebar in 60 seconds, detaches as a shoulder bag, and doubles as a car seat booster &mdash; so your small dog or cat can come along for every adventure.
          </p>

          <div class="rpb-hero__meta">
            {%- if lp != blank -%}
              <span class="rpb-hero__price">{{ lp.price | money }}</span>
              <span class="rpb-hero__badge">Free shipping on orders over $50</span>
            {%- endif -%}
          </div>

          <div class="rpb-hero__actions">
            <a href="{{ lp.url | default: '/collections/all' }}" class="rpb-btn rpb-btn--primary rpb-btn--lg">
              Shop Now
            </a>
          </div>

          <p class="rpb-hero__trust-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Fits pets up to 11 lbs &nbsp;&middot;&nbsp; 60-second install &nbsp;&middot;&nbsp; No tools needed
          </p>
        </div>

        <div class="rpb-hero__image-wrap rpb-animate">
          {%- comment -%}
            HERO IMAGE PLACEHOLDER
            Replace this div with:
              <img src="{{ 'your-hero-photo.jpg' | asset_url }}" alt="Small dog riding in RidePaw basket on a bike" loading="eager" width="900" height="1080">
            Recommended: warm outdoor lifestyle shot, pet in basket on bike. 900×1080px.
