{% comment %} ===== JAVASCRIPT ===== {% endcomment %}
<script>
(function () {
  'use strict';

  /* ---- FAQ Accordion ---- */
  var faqItems = document.querySelectorAll('.rpb-faq-item');

  faqItems.forEach(function (item) {
    var trigger = item.querySelector('.rpb-faq-trigger');
    var answer  = item.querySelector('.rpb-faq-answer');
    if (!trigger || !answer) return;

    trigger.addEventListener('click', function () {
      var isOpen = item.classList.contains('rpb-faq-item--open');

      /* Close all others */
      faqItems.forEach(function (other) {
        if (other === item) return;
        other.classList.remove('rpb-faq-item--open');
        var otherTrigger = other.querySelector('.rpb-faq-trigger');
        var otherAnswer  = other.querySelector('.rpb-faq-answer');
        if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
        if (otherAnswer)  otherAnswer.style.maxHeight = null;
      });

      /* Toggle current */
      if (isOpen) {
        item.classList.remove('rpb-faq-item--open');
        trigger.setAttribute('aria-expanded', 'false');
        answer.style.maxHeight = null;
      } else {
        item.classList.add('rpb-faq-item--open');
        trigger.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });

  /* ---- Scroll-in animations (IntersectionObserver) ---- */
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('rpb-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.rpb-animate').forEach(function (el) {
      io.observe(el);
    });
  } else {
    /* Fallback for older browsers: show everything immediately */
    document.querySelectorAll('.rpb-animate').forEach(function (el) {
      el.classList.add('rpb-visible');
    });
  }

})();
</script>

